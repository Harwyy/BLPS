  <bpmn:process id="restaurant_process" name="Процесс ресторана" isExecutable="true">
    <bpmn:laneSet id="LaneSet_0ytvc4g">
      <bpmn:lane id="Lane_1pm715o" name="Server">
        <bpmn:flowNodeRef>loadOrderItems</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_1jgj6s5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>rejectOrderByRest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endEventCancelByRestauranta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>confirmOrderByRest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>courierNotification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endEventRestauranta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>markOrderReady</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_1y1aws6" name="Restaurant">
        <bpmn:flowNodeRef>startEventRestaurant</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>commitOrderByRest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>markOrderReadyForm</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="startEventRestaurant" name="Начало процесса ресторана">
      <bpmn:outgoing>Flow_0iny2l0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="loadOrderItems" name="Загрузить информацию о товаре">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="load-order-items" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0iny2l0</bpmn:incoming>
      <bpmn:outgoing>Flow_1b0kpax</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="commitOrderByRest" name="Подтвердить заказ">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="restaurant_decision_form" />
        <zeebe:assignmentDefinition assignee="restaurant" candidateUsers="restaurant" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1b0kpax</bpmn:incoming>
      <bpmn:outgoing>Flow_1kcd1g3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_1jgj6s5" name="Подтвердил ли ресторана заказ?">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_1kcd1g3</bpmn:incoming>
      <bpmn:outgoing>Flow_1wipqap</bpmn:outgoing>
      <bpmn:outgoing>Flow_0h53ejx</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="rejectOrderByRest" name="Установка статуса CANCELLED_BY_REST">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="reject-order-by-rest" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0h53ejx</bpmn:incoming>
      <bpmn:outgoing>Flow_1iuo9xz</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="endEventCancelByRestauranta" name="Конец: отмена заказа рестораном">
      <bpmn:incoming>Flow_1iuo9xz</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="confirmOrderByRest" name="Установка статуса PREPARING">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="confirm-order-by-rest" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1wipqap</bpmn:incoming>
      <bpmn:outgoing>Flow_1mfp9f2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0iny2l0" sourceRef="startEventRestaurant" targetRef="loadOrderItems" />
    <bpmn:sequenceFlow id="Flow_1b0kpax" sourceRef="loadOrderItems" targetRef="commitOrderByRest" />
    <bpmn:sequenceFlow id="Flow_1kcd1g3" sourceRef="commitOrderByRest" targetRef="Gateway_1jgj6s5" />
    <bpmn:sequenceFlow id="Flow_1wipqap" name="Подтвержден" sourceRef="Gateway_1jgj6s5" targetRef="confirmOrderByRest">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=restaurant_decision = "confirm"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0h53ejx" name="Отклонен" sourceRef="Gateway_1jgj6s5" targetRef="rejectOrderByRest">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=restaurant_decision = "reject"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1iuo9xz" sourceRef="rejectOrderByRest" targetRef="endEventCancelByRestauranta" />
    <bpmn:sequenceFlow id="Flow_1mfp9f2" sourceRef="confirmOrderByRest" targetRef="markOrderReadyForm" />
    <bpmn:sequenceFlow id="Flow_061lnjn" sourceRef="courierNotification" targetRef="endEventRestauranta" />
    <bpmn:userTask id="markOrderReadyForm" name="Заказ готов">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="mark_order_ready_form" />
        <zeebe:assignmentDefinition assignee="restaurant" candidateUsers="restaurant" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1mfp9f2</bpmn:incoming>
      <bpmn:outgoing>Flow_0yoiqm7</bpmn:outgoing>
    </bpmn:userTask>
