    <bpmn:sequenceFlow id="Flow_1bb539w" sourceRef="unknownAddress" targetRef="endEventUnknownAddress" />
    <bpmn:sequenceFlow id="Flow_01que5f" sourceRef="createOrderObject" targetRef="processOrderItems" />
